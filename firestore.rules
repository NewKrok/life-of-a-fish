rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Community levels ──
    // Public read. Authenticated owners create/update/delete their own docs.
    // Size/shape constraints enforced here; rate-limits are best-effort
    // client-side (+ App Check) for now.
    match /levels/{levelId} {

      function isSignedIn() { return request.auth != null; }
      function isOwner()    { return isSignedIn() && resource.data.ownerId == request.auth.uid; }

      function validName(n)     { return n is string && n.size() > 0 && n.size() <= 50; }
      function validCode(c)     { return c is string && c.matches('LOAF-[A-Z0-9]{6}'); }
      function validLevelData(d) {
        return d is map
          && d.keys().hasAll(['cols', 'rows', 'strings', 'entities'])
          && d.cols is int && d.cols > 0 && d.cols <= 500
          && d.rows is int && d.rows > 0 && d.rows <= 100
          && d.strings is list
          && d.entities is list
          && d.entities.size() <= 2000;
      }

      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && validName(request.resource.data.name)
        && validCode(request.resource.data.code)
        && validLevelData(request.resource.data.data)
        && request.resource.data.plays == 0
        && request.resource.data.ratingSum == 0
        && request.resource.data.ratingCount == 0
        && request.resource.data.flagged == 0
        && request.resource.data.featured == false
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      // Owner can update name + data + updatedAt. Immutable fields may not change.
      // Counters (plays/rating/flagged/featured) are server-managed only
      // for now — owners cannot touch them.
      allow update: if isOwner()
        && request.resource.data.ownerId == resource.data.ownerId
        && request.resource.data.code == resource.data.code
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.plays == resource.data.plays
        && request.resource.data.ratingSum == resource.data.ratingSum
        && request.resource.data.ratingCount == resource.data.ratingCount
        && request.resource.data.flagged == resource.data.flagged
        && request.resource.data.featured == resource.data.featured
        && validName(request.resource.data.name)
        && validLevelData(request.resource.data.data)
        && request.resource.data.updatedAt == request.time;

      allow delete: if isOwner();

      // ── Ratings (subcollection; used by future #14) ──
      match /ratings/{raterUid} {
        allow read: if true;
        allow write: if isSignedIn()
          && raterUid == request.auth.uid
          && request.resource.data.stars is int
          && request.resource.data.stars >= 1
          && request.resource.data.stars <= 5;
      }

      // ── Reports (one per user per level) ──
      // Doc ID must equal the reporter's uid, which enforces one-report-per-user
      // without needing any counter logic. Reports are not publicly readable —
      // only the reporter and admins (future) can read their own.
      match /reports/{reporterUid} {
        allow read: if isSignedIn() && reporterUid == request.auth.uid;
        allow create: if isSignedIn()
          && reporterUid == request.auth.uid
          && request.resource.data.reporterId == request.auth.uid
          && request.resource.data.reason is string
          && request.resource.data.reason.size() <= 200;
        allow update, delete: if false;
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
